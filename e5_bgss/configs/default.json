{
  "run_tag": "default",
  "model_name": "gpt2",
  "dataset": {
    "name": "wikitext",
    "config_name": "wikitext-2-raw-v1",
    "split": "train",
    "text_field": "text"
  },
  "train_precision": "fp32",
  "target_precision": "fp16",
  "sequence_length": 256,
  "batch_size": 1,
  "seeds": [0, 1, 2],
  "policies": ["none", "static_global", "random_same_budget", "bgss"],
  "max_train_sequences": 512,
  "max_train_steps": 256,
  "stride": 0,
  "shuffle_windows": true,
  "learning_rate": 0.0006,
  "weight_decay": 0.0,
  "gradient_clip_norm": 1.0,
  "lr_warmup_steps": 20,
  "monitor_interval": 1,
  "softmax_row_samples": 16,
  "softmax_power_iters": 2,
  "event_warmup_steps": 24,
  "rolling_window": 12,
  "mismatch_spike_ratio": 1.22,
  "loss_spike_ratio": 1.2,
  "event_cooldown_steps": 16,
  "base_epsilon": 1e-05,
  "static_epsilon": 0.001,
  "epsilon_multiplier": 4.0,
  "epsilon_max": 0.01,
  "controller_warmup_steps": 24,
  "controller_trigger_quantile": 0.8,
  "max_total_actions": 24,
  "max_actions_per_step": 2,
  "max_actions_per_layer": 6,
  "cooldown_steps": 10,
  "bgss_ln_bonus_weight": 1.0,
  "bgss_update_headroom_weight": 0.75,
  "bgss_update_repetition_penalty": 0.6,
  "random_candidate_scope": "all_layers",
  "device": "auto",
  "trust_remote_code": false
}
